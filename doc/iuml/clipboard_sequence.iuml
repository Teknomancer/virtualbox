@startuml
title VirtualBox Clipboard API Sequence - 7.x Draft
hide empty description
skinparam shadowing false
skinparam dpi 96
skinparam sequenceGroupBackgroundColor #F7F7F7
skinparam sequenceDividerBackgroundColor #EEEEEE

box "Host side" #E8F2FF
actor "User (Host)" as UH
participant "Native Host\nClipboard" as H
participant "API Client /\nFrontend" as Client
participant "VBoxC / Main" as VBoxC
end box

box "Guest side" #EAF7EA
participant "VBoxService\nGuest Additions" as VBoxService
participant "Guest\nClipboard" as G
actor "User (Guest)" as UG
end box

legend right
  Blue area: host-side API client, Main/VBoxC and native host clipboard.
  Green area: guest-side Guest Additions service and guest clipboard.
  VBoxSVC is intentionally absent; these paths are driven through VBoxC/Main.
endlegend

== Host -> Guest (Data) ==

UH -> H: Copy data, for example Ctrl+C
H -> VBoxC: Native backend observes host formats
VBoxC -> Client: OnClipboardFormatChanged(Host, formats)
Client -> VBoxC : IClipboard::createFormat(mimeType)
Client -> VBoxC : IClipboard::writeFormats(formats)
VBoxC -> VBoxService  : queue VBOX_SHCL_HOST_MSG_FORMATS_REPORT
VBoxService -> G  : report formats to guest clipboard
UG -> G: Paste data, for example Ctrl+V
G -> VBoxService  : VBOX_SHCL_GUEST_FN_DATA_READ(format)
VBoxService -> VBoxC  : request cached host data for guest
VBoxC -> Client : OnClipboardDataChanged after data is read
Client -> VBoxC : IClipboard::createFormat(mimeType)
Client -> VBoxC : IClipboard::createItem(Host, format, buffer)
Client -> VBoxC : IClipboard::writeData(Copy, item)
VBoxC -> VBoxService  : provide data for VBOX_SHCL_GUEST_FN_DATA_READ
VBoxService -> G  : return data to guest clipboard

== Guest -> Host (Data) ==

UG -> G: Copy data, for example Ctrl+C
G -> VBoxService : Guest clipboard reports formats
VBoxService -> VBoxC : VBOX_SHCL_GUEST_FN_REPORT_FORMATS(formats)
VBoxC -> Client: OnClipboardFormatChanged(Guest, formats)
Client -> VBoxC : IClipboard::readFormats()
Client -> VBoxC : IClipboard::readData(Copy)
VBoxC -> VBoxService : queue VBOX_SHCL_HOST_MSG_READ_DATA[_CID](format)
VBoxService -> G : read requested guest clipboard format
G -> VBoxService : VBOX_SHCL_GUEST_FN_DATA_WRITE(format, data)
VBoxService -> VBoxC : report guest data
VBoxC -> Client : OnClipboardDataChanged(Guest)
Client -> VBoxC : IClipboard::writeData(Copy, item)
VBoxC -> H : write to native host clipboard

== Host -> Guest (Files) ==

UH -> H: Copy file or directory
H -> VBoxC: Native backend reports local source paths
VBoxC -> VBoxC: create IClipboardTransfer(ToGuest)
VBoxC -> VBoxC: setSourcePaths(host local paths)
note right of VBoxC
  sourcePaths are producer-side local paths,
  for example /home/user/report.txt.
  The guest only sees transfer roots,
  for example report.txt.
end note
VBoxC -> Client: OnClipboardTransfer(Added, Approval)
Client -> VBoxC: IClipboardTransferManager::approve(transfer, 0)
VBoxC -> VBoxService: advertise transfer roots and metadata
UG -> G: Paste into guest directory
G -> VBoxService: request transfer roots/list/object data
VBoxService -> VBoxC: request IClipboardTransfer roots/list/openFile/read
VBoxC -> VBoxService: stream file data and directory metadata
VBoxService -> G: materialize files/directories in guest
VBoxC -> Client: OnClipboardTransfer(Completed)

== Guest -> Host (Files) ==

UG -> G: Copy file or directory
G -> VBoxService: report transfer roots and metadata
note right of VBoxService
  Guest-to-host offers normally provide
  receiver-visible transfer roots directly.
  getSourcePaths() may be empty because
  there are no host-local source paths.
end note
VBoxService -> VBoxC: create IClipboardTransfer(ToHost)
VBoxC -> Client: OnClipboardTransfer(Added, Approval)
Client -> VBoxC: IClipboardTransferManager::approve(transfer, 0)
VBoxC -> H: publish native host file offer
UH -> H: Paste into host directory
H -> VBoxC: request transfer roots/list/openFile/read
VBoxC -> VBoxService: request object/list data from guest
VBoxService -> G: read guest files/directories
G -> VBoxService: stream file data and directory metadata
VBoxService -> VBoxC: return transfer data
VBoxC -> H: materialize requested files/directories
VBoxC -> Client: OnClipboardTransfer(Completed)

@enduml
' EOF
