@startuml
title VirtualBox Clipboard IClipboardTransfer Sequence - 7.x Draft
hide empty description
skinparam shadowing false
skinparam dpi 96
skinparam sequenceGroupBackgroundColor #F7F7F7
skinparam sequenceDividerBackgroundColor #EEEEEE

box "API client side" #E8F2FF
actor "API Client /\nFrontend" as Client
participant "IClipboardTransferManager" as Manager
participant "IClipboardTransfer" as Transfer
participant "IClipboardTransferDirectory" as Directory
participant "IClipboardTransferFile" as File
end box

box "VBoxC / Main" #FFF4DA
participant "VBoxC / Main\ntransfer wrapper" as VBoxC
participant "Shared Clipboard\ntransfer core" as Core
end box

box "Provider / peer side" #EAF7EA
participant "Transfer provider\nlocal, guest, virtual" as Provider
participant "Source or sink\nfilesystem" as Fs
end box

legend right
  IClipboardTransfer is the high-level filesystem-like transfer tree API.
  sourcePaths configure local producer-side filesystem objects.
  roots() returns receiver-visible transfer-relative nodes.
  Roots, query, list, openDirectory and openFile are preferred for normal clients.
  IClipboardTransferData is the low-level fallback for protocol diagnostics.
  Transfer paths shown here are relative and must not be host or guest absolute paths.
endlegend

== Configure a local host-to-guest transfer ==

Client -> Manager: createTransfer(ToGuest, Host, Copy)
Manager -> VBoxC: create unpublished transfer wrapper
VBoxC --> Manager: transfer
Manager --> Client: transfer

Client -> Transfer: setSourcePaths(["/home/user/report.txt", "/home/user/photos"])
note right of Client
  sourcePaths are local producer-side paths.
  They are not visible transfer paths.
end note
Transfer -> VBoxC: configure local provider backend
VBoxC -> Core: create local roots from source paths
Core -> Provider: validate and register source objects
Provider -> Fs: stat /home/user/report.txt and /home/user/photos
Fs --> Provider: source metadata
Provider --> Core: accepted source roots
Core --> VBoxC: initialized transfer tree
VBoxC --> Transfer: success
Transfer --> Client: success

Client -> Manager: add(transfer)
Manager -> VBoxC: publish configured transfer
VBoxC -> Core: make transfer available
Core -> Provider: advertise roots report.txt and photos

== Discover and approve a transfer ==

Client -> Manager: getTransfers(direction, 0)
Manager -> VBoxC: find matching live transfers
VBoxC --> Manager: matching transfers
Manager --> Client: transfer[]

Client -> Transfer: getDirection(), getSource(), getState()
Transfer -> VBoxC: read transfer metadata
VBoxC --> Transfer: direction, source, state
Transfer --> Client: transfer metadata

opt transfer waits for client approval
  Client -> Manager: approve(transfer, 0)
  Manager -> VBoxC: validate transfer identity and policy
  VBoxC -> Core: continue approved transfer
  Core -> Provider: start or accept provider flow
end

== Inspect transfer roots ==

Client -> Transfer: roots()
note right of Client
  roots() returns transfer-relative nodes visible
  to the receiver. For the sourcePaths example
  above, roots are report.txt and photos.
end note
Transfer -> VBoxC: high-level root query
VBoxC -> Core: enumerate transfer roots
Core -> Provider: query root metadata
Provider -> Fs: stat/query source objects or virtual roots
Fs --> Provider: metadata
Provider --> Core: root entries
Core --> VBoxC: root entries
VBoxC --> Transfer: IClipboardTransferFsObjInfo[]
Transfer --> Client: roots with path, flags and IFsObjInfo data

loop for each interesting root or path
  Client -> Transfer: query("root/path")
  Transfer -> VBoxC: validate transfer-relative path
  VBoxC -> Core: query node metadata
  Core -> Provider: query node
  Provider -> Fs: stat/query file, directory or virtual node
  Fs --> Provider: metadata
  Provider --> Core: metadata
  Core --> VBoxC: node metadata
  VBoxC --> Transfer: IClipboardTransferFsObjInfo
  Transfer --> Client: node info
end

== List a directory tree ==

Client -> Transfer: list("root/dir", 0)
note right of Client
  Listing is recursive by default.
  Use ClipboardTransferListFlag_NoRecursion
  to request immediate children only.
end note
Transfer -> VBoxC: validate path and flags
VBoxC -> Core: open/read/close provider lists as needed
Core -> Provider: enumerate directory recursively
Provider -> Fs: read/query entries
Fs --> Provider: entry metadata
Provider --> Core: recursive entries
Core --> VBoxC: transfer-relative nodes
VBoxC --> Transfer: IClipboardTransferFsObjInfo[]
Transfer --> Client: complete node list

Client -> Transfer: list("root/dir", NoRecursion)
Transfer -> VBoxC: validate path and flags
VBoxC -> Core: enumerate immediate children only
Core -> Provider: list one directory level
Provider --> Core: entries
Core --> VBoxC: entries
VBoxC --> Transfer: IClipboardTransferFsObjInfo[]
Transfer --> Client: immediate children

== Use a directory handle ==

Client -> Transfer: openDirectory("root/dir", NoRecursion)
Transfer -> VBoxC: validate transfer-relative directory path
VBoxC -> Core: open provider list
Core -> Provider: open directory
Provider -> Fs: open directory or virtual directory
Fs --> Provider: directory handle
Provider --> Core: list handle
Core --> VBoxC: list handle
VBoxC --> Transfer: IClipboardTransferDirectory
Transfer --> Client: directory

loop while entries are needed
  Client -> Directory: listEx(maxEntries, NoRecursion)
  Directory -> VBoxC: read directory entries
  VBoxC -> Core: ShClTransferListRead()
  Core -> Provider: read entries
  Provider -> Fs: read/query entries
  Fs --> Provider: entry metadata
  Provider --> Core: entries
  Core --> VBoxC: entries
  VBoxC --> Directory: IClipboardTransferFsObjInfo[]
  Directory --> Client: entries
end

Client -> Directory: rewind()
Directory -> VBoxC: close and reopen list
VBoxC -> Core: reset directory enumeration
Core -> Provider: reopen directory
Provider --> Core: new list handle
Core --> VBoxC: new list handle
VBoxC --> Directory: reset complete
Directory --> Client: success

Client -> Directory: close()
Directory -> VBoxC: close list handle
VBoxC -> Core: ShClTransferListClose()
Core -> Provider: close directory
Provider -> Fs: close directory

== Read a file through IFile ==

Client -> Transfer: openFile("root/dir/file.txt", ReadOnly, OpenExisting, All, 0, 0)
Transfer -> VBoxC: validate path and open mode
VBoxC -> Core: open transfer object
Core -> Provider: open file or generated stream
Provider -> Fs: open file or virtual stream
Fs --> Provider: object handle
Provider --> Core: object handle
Core --> VBoxC: object handle
VBoxC --> Transfer: IClipboardTransferFile
Transfer --> Client: file

Client -> File: queryInfo()
File -> VBoxC: query opened object metadata
VBoxC -> Core: query object info
Core -> Provider: query object
Provider --> Core: metadata
Core --> VBoxC: metadata
VBoxC --> File: IFsObjInfo
File --> Client: file metadata

loop until EOF
  Client -> File: read(chunkSize, timeoutMS)
  File -> VBoxC: read object bytes
  VBoxC -> Core: ShClTransferObjRead()
  Core -> Provider: read file bytes
  Provider -> Fs: read file or generate bytes
  Fs --> Provider: bytes
  Provider --> Core: bytes
  Core --> VBoxC: bytes
  VBoxC --> File: bytes
  File --> Client: data
end

Client -> File: close()
File -> VBoxC: close object handle
VBoxC -> Core: ShClTransferObjClose()
Core -> Provider: close object
Provider -> Fs: close file or stream

== Create or write nodes when supported ==

note over Client,Provider
  Writable and virtual/ad-hoc trees are provider- and direction-dependent.
  Receivers still validate transfer-relative paths before materializing files.
end note

Client -> Transfer: createDirectory("target/generated", Writable)
Transfer -> VBoxC: validate path and flags
VBoxC -> Core: create directory node when provider supports it
Core -> Provider: create physical or virtual directory
Provider -> Fs: create directory or record virtual directory
Fs --> Provider: created
Provider --> Core: success
Core --> VBoxC: success
VBoxC --> Transfer: success
Transfer --> Client: success

Client -> Transfer: openFile("target/generated/report.txt", WriteOnly, CreateOrReplace, All, mode, Writable)
Transfer -> VBoxC: validate path and open mode
VBoxC -> Core: open writable object
Core -> Provider: create/open writable file or generated object
Provider --> Core: object handle
Core --> VBoxC: object handle
VBoxC --> Transfer: IClipboardTransferFile
Transfer --> Client: file

loop for each generated chunk
  Client -> File: write(bytes, timeoutMS)
  File -> VBoxC: write object bytes
  VBoxC -> Core: ShClTransferObjWrite()
  Core -> Provider: write or store bytes
  Provider -> Fs: write physical bytes or memory-backed payload
  Fs --> Provider: bytes accepted
  Provider --> Core: bytes written
  Core --> VBoxC: bytes written
  VBoxC --> File: bytes written
  File --> Client: written
end

Client -> File: close()
File -> VBoxC: close and finalize writable object
VBoxC -> Core: ShClTransferObjClose()
Core -> Provider: finalize file or virtual object
Provider -> Fs: publish object

== Handle transfer interactions ==

VBoxC --> Client: IClipboardTransferEvent(Interaction, Overwrite, path)
alt overwrite allowed
  Client -> Manager: respond(transfer, Overwrite, path, Overwrite, "", 0)
  Manager -> VBoxC: validate path, response and transfer identity
  VBoxC -> Core: continue with overwrite decision
else rename requested
  Client -> Manager: respond(transfer, Rename, path, Rename, "renamed-file.txt", 0)
  Manager -> VBoxC: validate path and responsePath
  VBoxC -> Core: continue with renamed destination
else transfer denied or canceled
  Client -> Manager: deny(transfer, reason)
  Manager -> VBoxC: cancel or fail transfer
  VBoxC -> Core: abort transfer
end

VBoxC --> Client: IClipboardTransferEvent(Completed or Failed, None, "")

@enduml
' EOF
