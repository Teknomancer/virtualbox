@startuml
title VirtualBox Clipboard IClipboardTransferData Sequence - 7.x Draft
hide empty description
skinparam shadowing false
skinparam dpi 96
skinparam sequenceGroupBackgroundColor #F7F7F7
skinparam sequenceDividerBackgroundColor #EEEEEE

box "API client side" #E8F2FF
actor "API Client /\nFrontend" as Client
participant "IClipboardTransferManager" as Manager
participant "IClipboardTransfer" as Transfer
participant "IClipboardTransferData" as Data
end box

box "VBoxC / Main" #FFF4DA
participant "VBoxC / Main\ntransfer wrapper" as VBoxC
participant "Shared Clipboard\ntransfer core" as Core
end box

box "Provider / peer side" #EAF7EA
participant "Transfer provider\nlocal, guest, virtual" as Provider
participant "Source or sink\nfilesystem" as Fs
end box

legend right
  IClipboardTransferData is the low-level root/list/object data plane.
  RootList entries are transfer roots, not producer-side sourcePaths.
  Prefer IClipboardTransfer::roots, list, openDirectory and openFile for normal clients.
  Paths shown here are transfer-relative and must not be host or guest absolute paths.
endlegend

== Discover an available transfer ==

Client -> Manager: getTransfers(direction, 0)
Manager -> VBoxC: find matching live transfers
VBoxC --> Manager: matching transfers
Manager --> Client: transfer[]
Client -> Transfer: getData()
Transfer -> VBoxC: create or return retained data wrapper
VBoxC --> Transfer: IClipboardTransferData
Transfer --> Client: data

== Read roots and metadata ==

note over Client,Data
  If a local transfer was configured with sourcePaths such as
  /home/user/report.txt, RootList reads return transfer root names
  such as report.txt, not the original local source path.
end note

Client -> Data: open(RootList, "", "", 0)
Data -> Core: ShClTransferRootsCount()
Core --> Data: root count
Data --> Client: count

loop root index 0 .. count - 1
  Client -> Data: read(RootList, index, 0, 0)
  Data -> Core: ShClTransferRootsEntryGet(index)
  Core -> Provider: query root metadata
  Provider -> Fs: stat/query source root
  Fs --> Provider: metadata
  Provider --> Core: name, infoFlags, info
  Core --> Data: root entry
  Data --> Client: name, infoFlags, info, empty data
end

== Enumerate a directory ==

Client -> Data: open(List, "root/dir", "*", flags)
Data -> Core: ShClTransferListOpen("root/dir", "*", flags)
Core -> Provider: open list
Provider -> Fs: open directory
Fs --> Provider: directory handle
Provider --> Core: list handle
Core --> Data: list handle
Data --> Client: handle

loop until end of directory
  Client -> Data: read(List, handle, 0, 0)
  Data -> Core: ShClTransferListRead(handle)
  Core -> Provider: read next entry
  Provider -> Fs: read/query entry
  Fs --> Provider: entry metadata
  Provider --> Core: name, infoFlags, info
  Core --> Data: list entry
  Data --> Client: name, infoFlags, info, empty data
end

Client -> Data: close(List, handle)
Data -> Core: ShClTransferListClose(handle)
Core -> Provider: close list
Provider -> Fs: close directory

== Read a file object ==

Client -> Data: open(Object, "root/dir/file.txt", "", objectOpenFlags)
Data -> Core: ShClTransferObjOpen("root/dir/file.txt", objectOpenFlags)
Core -> Provider: open object
Provider -> Fs: open file or generated stream
Fs --> Provider: object handle
Provider --> Core: object handle
Core --> Data: object handle
Data --> Client: handle

loop until EOF
  Client -> Data: read(Object, handle, chunkSize, 0)
  Data -> Core: ShClTransferObjRead(handle, chunkSize)
  Core -> Provider: read object bytes
  Provider -> Fs: read file or generate bytes
  Fs --> Provider: bytes
  Provider --> Core: bytes
  Core --> Data: bytes
  Data --> Client: empty name/info, data bytes
end

Client -> Data: close(Object, handle)
Data -> Core: ShClTransferObjClose(handle)
Core -> Provider: close object
Provider -> Fs: close file or stream

== Write virtual or received content ==

note over Client,Provider
  This path is only available when the transfer direction and provider are writable.
  It is suitable for receiving files or publishing virtual/generated content.
end note

Client -> Data: open(List, "target/dir", "", createListFlags)
Data -> Core: ShClTransferListOpen("target/dir", "", createListFlags)
Core -> Provider: open writable list
Provider --> Core: list handle
Core --> Data: list handle
Data --> Client: handle

Client -> Data: write(List, handle, "new-file.txt", infoFlags, info, empty, 0)
Data -> Core: ShClTransferListWrite(handle, entry metadata)
Core -> Provider: create or record directory entry
Provider -> Fs: create virtual/physical entry
Fs --> Provider: entry accepted
Provider --> Core: success
Core --> Data: success
Data --> Client: written = 0

Client -> Data: open(Object, "target/dir/new-file.txt", "", createObjectFlags)
Data -> Core: ShClTransferObjOpen("target/dir/new-file.txt", createObjectFlags)
Core -> Provider: open writable object
Provider --> Core: object handle
Core --> Data: object handle
Data --> Client: handle

loop for each payload chunk
  Client -> Data: write(Object, handle, "", 0, empty, bytes, 0)
  Data -> Core: ShClTransferObjWrite(handle, bytes)
  Core -> Provider: write object bytes
  Provider -> Fs: write physical bytes or store generated payload
  Fs --> Provider: bytes accepted
  Provider --> Core: bytes written
  Core --> Data: bytes written
  Data --> Client: written
end

Client -> Data: close(Object, handle)
Data -> Core: ShClTransferObjClose(handle)
Core -> Provider: finalize object
Provider -> Fs: close or publish generated object

Client -> Data: close(List, handle)
Data -> Core: ShClTransferListClose(handle)
Core -> Provider: close writable list

@enduml
' EOF
